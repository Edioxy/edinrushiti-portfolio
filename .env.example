# Admin panel environment variables
# Copy these into Vercel → Project → Settings → Environment Variables

# Required: password you use to sign in at /admin
ADMIN_PASSWORD=choose-a-strong-password-here

# Required in production: GitHub token so Save updates your live site automatically
# Create at: https://github.com/settings/tokens
# Permissions needed: Contents (Read and write) on edinrushiti-portfolio repo
GITHUB_TOKEN=

# Optional: defaults to Edioxy/edinrushiti-portfolio
GITHUB_REPO=Edioxy/edinrushiti-portfolio
